#!/usr/bin/env python3
"""<REPO> V1.2 wild scan — Phase 5 prose + Phase 6 assembly."""
import json
from datetime import datetime, timezone
from pathlib import Path

FORM_PATH = Path(__file__).resolve().parent / "form.json"

# Editorial caption — under ~400 chars to land within validator's first-1500-byte
# verdict-extraction window (longer captions push the verdict marker past the limit).
EDITORIAL_CAPTION = (
    "<REPO> — <one-line summary mentioning star count, age, primary language, "
    "verdict driver. End with explicit verdict word: Caution / Critical / Clean.>"
)

# One per finding. body_paragraphs is typically 2-3 paragraphs:
#   1. The factual surface (what evidence shows)
#   2. The threat-model context (why it matters / what blast radius)
#   3. Mitigation framing (consumer-side + maintainer-side)
PER_FINDING_PROSE = [
    {
        "finding_id": "F0",
        "body_paragraphs": [
            "<paragraph 1 — what the evidence shows>",
            "<paragraph 2 — threat model context>",
            "<paragraph 3 — mitigation framing>",
        ],
    },
    # ... one entry per finding in FINDINGS
]


def main():
    form = json.loads(FORM_PATH.read_text())

    form["phase_5_prose_llm"] = {
        "editorial_caption": {"text": EDITORIAL_CAPTION},
        "per_finding_prose": {"entries": PER_FINDING_PROSE},
    }

    form["phase_6_assembly"] = {
        "assembled": True,
        "assembly_timestamp": datetime.now(timezone.utc).isoformat(),
        "provenance_complete": True,
        "evidence_refs_valid": True,
        "field_count": sum(1 for _ in _walk(form)),
    }

    form["_meta"]["scan_status"] = "completed"

    FORM_PATH.write_text(json.dumps(form, indent=2, default=str))
    print(f"✓ Phase 5 + Phase 6 written.")
    print(f"  editorial_caption: {len(EDITORIAL_CAPTION)} chars")
    print(f"  per_finding_prose entries: {len(PER_FINDING_PROSE)}")

    from jsonschema import Draft202012Validator
    REPO_ROOT = Path(__file__).resolve().parent.parent.parent
    schema = json.loads((REPO_ROOT / "docs" / "scan-schema.json").read_text())
    errors = list(Draft202012Validator(schema).iter_errors(form))
    if errors:
        print(f"\n✗ Schema: {len(errors)} error(s)")
        for e in errors[:5]:
            print(f"  - {'/'.join(str(p) for p in e.absolute_path)}: {e.message[:160]}")
    else:
        print("\n✓ Schema: CLEAN (full form)")


def _walk(obj, count=[0]):
    if isinstance(obj, dict):
        for k, v in obj.items():
            count[0] += 1
            yield from _walk(v)
    elif isinstance(obj, list):
        for v in obj:
            yield from _walk(v)
    else:
        count[0] += 1
        yield obj


if __name__ == "__main__":
    main()
