{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stop-git-std.local/scan-schema.json",
  "title": "GitHub Repo Security Scanner — Investigation Form",
  "description": "Validates a completed investigation form (V1.1). LLM fills phases 1-5 incrementally; Python computes phase 3; renderer consumes the complete form.",
  "$comment": "V1.1 — schema freeze per 2026-04-18 board review (docs/External-Board-Reviews/041826-renderer-alignment/CONSOLIDATION.md). Adds renderer-driven structures (verdict_exhibits, executable_file_inventory, pr_sample_review, coverage_detail, evidence.entries, repo_vitals, section_leads). Reconciles stale shapes (timeline_event, action_step, meta_table_row). Enforces C2 (F12 fields on security-relevant executable entries) and C3 (auto_load_tier on agent-rule-file findings). V1.2 will re-bind C3 trigger to domain==agent per SD2 deferred roadmap.",
  "type": "object",
  "required": [
    "schema_version",
    "_meta",
    "target",
    "phase_1_raw_capture",
    "phase_2_validation",
    "phase_3_computed",
    "phase_4_structured_llm",
    "phase_4b_computed",
    "phase_5_prose_llm",
    "phase_6_assembly"
  ],
  "properties": {
    "$comment": { "type": "string" },
    "schema_version": {
      "type": "string",
      "description": "Semantic version of the form schema"
    },
    "_meta": { "$ref": "#/$defs/meta" },
    "target": { "$ref": "#/$defs/target" },
    "scanner_integrity": { "$ref": "#/$defs/scanner_integrity" },
    "phase_1_raw_capture": { "$ref": "#/$defs/phase_1_raw_capture" },
    "phase_2_validation": { "$ref": "#/$defs/phase_2_validation" },
    "phase_3_computed": { "$ref": "#/$defs/phase_3_computed" },
    "phase_4_structured_llm": { "$ref": "#/$defs/phase_4_structured_llm" },
    "phase_4b_computed": { "$ref": "#/$defs/phase_4b_computed" },
    "phase_5_prose_llm": { "$ref": "#/$defs/phase_5_prose_llm" },
    "phase_6_assembly": { "$ref": "#/$defs/phase_6_assembly" },
    "scan_sign_off": { "$ref": "#/$defs/scan_sign_off" }
  },
  "additionalProperties": false,

  "$defs": {

    "severity": {
      "type": "string",
      "enum": ["Critical", "Warning", "Info", "OK"]
    },

    "finding_status": {
      "type": "string",
      "enum": ["active", "resolved", "ongoing", "mitigated", "informational"]
    },

    "finding_provenance": {
      "type": "string",
      "enum": ["rule-applied", "synthesized", "observed"]
    },

    "scorecard_color": {
      "type": "string",
      "enum": ["red", "amber", "green"]
    },

    "coverage_status": {
      "type": "string",
      "enum": ["ok", "partial", "blocked", "not_available", "not_indexed", "not_queried", "unknown"]
    },

    "action_step_type": {
      "type": "string",
      "description": "Category of action step. Short forms (install, mitigate, nudge) are renderer-ready; long forms (install_normally, pin_version, ...) are the V1.0 prescriptive vocabulary kept for backwards compatibility.",
      "enum": [
        "install",
        "mitigate",
        "nudge",
        "verify",
        "audit",
        "upgrade",
        "avoid",
        "install_normally",
        "pin_version",
        "pin_commit",
        "set_config",
        "verify_artifact",
        "nudge_maintainer",
        "upgrade_required",
        "audit_before_use",
        "do_not_install"
      ]
    },

    "threat_model_path": {
      "type": "string",
      "enum": [
        "phishing",
        "stale_token",
        "session_compromise",
        "malicious_extension",
        "sloppy_review",
        "runner_compromise",
        "other"
      ]
    },

    "capability": {
      "type": "string",
      "enum": [
        "arbitrary_code_exec",
        "file_exfil",
        "filesystem_write",
        "network_access",
        "credential_access",
        "prompt_injection_channel",
        "persistence",
        "privilege_escalation",
        "none"
      ]
    },

    "split_axis": {
      "type": ["string", "null"],
      "enum": [null, "version", "deployment"]
    },

    "auto_load_tier": {
      "type": "string",
      "enum": [
        "tier_1_always",
        "tier_2_conditional",
        "tier_3_supporting",
        "tier_4_paste_install",
        "unknown"
      ]
    },

    "timeline_severity": {
      "type": "string",
      "enum": ["green", "yellow", "red"]
    },

    "meta": {
      "type": "object",
      "required": ["scan_status"],
      "properties": {
        "phases_completed": {
          "type": "array",
          "items": { "type": "string" }
        },
        "scan_status": {
          "type": "string",
          "enum": ["in_progress", "validated", "completed"]
        },
        "scanner_version": { "type": ["string", "null"] },
        "prompt_version": { "type": ["string", "null"] },
        "model": { "type": ["string", "null"] },
        "scan_started_at": { "type": ["string", "null"] },
        "scan_completed_at": { "type": ["string", "null"] },
        "assumptions": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },

    "target": {
      "type": "object",
      "required": ["owner", "repo", "full_name"],
      "properties": {
        "owner": { "type": ["string", "null"] },
        "repo": { "type": ["string", "null"] },
        "full_name": { "type": ["string", "null"] },
        "url": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },

    "scanner_integrity": {
      "type": "object",
      "properties": {
        "$comment": { "type": "string" },
        "injection_matches": { "type": ["integer", "null"] },
        "actionable_count": { "type": ["integer", "null"] },
        "findings": {
          "type": "array",
          "items": { "$ref": "#/$defs/finding" }
        }
      },
      "additionalProperties": false
    },

    "evidence": {
      "type": "object",
      "required": ["id", "claim", "command", "result", "classification"],
      "properties": {
        "id": { "type": "string" },
        "claim": { "type": "string" },
        "command": { "type": "string" },
        "command_lang": {
          "type": ["string", "null"],
          "description": "Code fence language for the command block (e.g. bash, yaml)"
        },
        "result": { "type": "string" },
        "result_lang": {
          "type": ["string", "null"],
          "description": "Code fence language for the result block (e.g. json, yaml)"
        },
        "result_truncated": { "type": "boolean", "default": false },
        "classification": { "type": "string" }
      },
      "additionalProperties": false
    },

    "priority_evidence_selection": {
      "type": "object",
      "required": ["evidence_id", "reason"],
      "properties": {
        "evidence_id": { "type": "string" },
        "reason": {
          "type": "string",
          "description": "Why this evidence is priority — per S8-7, should articulate what falsification of this claim would mean (would flip the verdict). If that can't be articulated, it isn't priority."
        }
      },
      "additionalProperties": false
    },

    "timeline_tone": {
      "type": "string",
      "enum": ["positive", "neutral", "negative", "warn"]
    },

    "timeline_event": {
      "type": "object",
      "required": ["date", "label", "tone", "note"],
      "properties": {
        "date": { "type": "string" },
        "label": {
          "type": "string",
          "maxLength": 40,
          "description": "Beat name — max ~3 words (forbidden: SCAN, START, TODAY restatements per S8-9)"
        },
        "tone": { "$ref": "#/$defs/timeline_tone" },
        "note": { "type": "string" }
      },
      "additionalProperties": false
    },

    "action_step": {
      "type": "object",
      "required": ["step", "type", "headline", "severity"],
      "properties": {
        "step": { "type": "integer", "minimum": 1 },
        "type": { "$ref": "#/$defs/action_step_type" },
        "headline": { "type": "string" },
        "severity": { "$ref": "#/$defs/severity" },
        "non_technical": { "type": ["string", "null"] },
        "command": { "type": ["string", "null"] },
        "command_lang": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },

    "meta_table_row": {
      "type": "object",
      "required": ["label", "value"],
      "properties": {
        "label": { "type": "string" },
        "value": { "type": "string" }
      },
      "additionalProperties": false
    },

    "verdict_exhibit_item": {
      "type": "object",
      "required": ["tag", "claim"],
      "properties": {
        "tag": { "type": "string", "description": "e.g. 'F0 / C20' or 'Governance · F0'" },
        "claim": { "type": "string" }
      },
      "additionalProperties": false
    },

    "verdict_exhibit_group": {
      "type": "object",
      "required": ["headline", "items"],
      "properties": {
        "symbol": { "type": ["string", "null"], "description": "Leading symbol like ⚠, ✓, 🚨" },
        "headline": { "type": "string" },
        "one_line_summary": { "type": ["string", "null"] },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/verdict_exhibit_item" }
        }
      },
      "additionalProperties": false
    },

    "executable_file_inventory_entry": {
      "type": "object",
      "required": ["path", "kind", "runtime"],
      "properties": {
        "path": { "type": "string" },
        "kind": { "type": "string" },
        "runtime": { "type": "string", "description": "Runtime context (Bundler, Node, shell, etc.)" },
        "dangerous_calls": { "type": ["string", "null"] },
        "network": { "type": ["string", "null"] },
        "notes": { "type": ["string", "null"] },
        "file_sha": {
          "type": ["string", "null"],
          "description": "C2 FIX NOW (V2.3 R3 C3): File SHA at scanned revision. Required when security-relevant (see allOf)."
        },
        "line_ranges": {
          "type": ["string", "null"],
          "description": "C2 FIX NOW (V2.3 R3 C3): Relevant lines (e.g. '45-78, 120-135'). Required when security-relevant."
        },
        "diff_anchor": {
          "type": ["string", "null"],
          "description": "C2 FIX NOW (V2.3 R3 C3): Diff anchor for reproducibility. Required when security-relevant."
        }
      },
      "allOf": [
        {
          "$comment": "C2 FIX NOW: file_sha, line_ranges, diff_anchor required when dangerous_calls is present (security-relevant entries). Codex dissent in R2: preferred always-required with explicit-null. Per R3/R4 resolution: conditional required for V1.1; re-evaluate in V1.2.",
          "if": {
            "properties": {
              "dangerous_calls": {
                "type": "string",
                "not": { "enum": ["None", "none", ""] }
              }
            },
            "required": ["dangerous_calls"]
          },
          "then": {
            "required": ["file_sha", "line_ranges", "diff_anchor"]
          }
        }
      ],
      "additionalProperties": false
    },

    "executable_file_inventory": {
      "type": "object",
      "properties": {
        "$comment": { "type": "string" },
        "lead": { "type": ["string", "null"], "description": "One-line section summary (Layer 1)" },
        "layer1_summary": { "type": ["string", "null"] },
        "layer2_entries": {
          "type": "array",
          "items": { "$ref": "#/$defs/executable_file_inventory_entry" }
        },
        "closing_note": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },

    "pr_sample_review_row": {
      "type": "object",
      "required": ["number", "what", "author", "merger"],
      "properties": {
        "number": { "type": "integer" },
        "url": { "type": ["string", "null"] },
        "what": { "type": "string", "description": "Short prose — what this PR did" },
        "author": { "type": "string" },
        "merger": { "type": "string" },
        "reviewed": { "type": ["string", "null"], "description": "Formal review decision or 'No formal decision'" },
        "concern": { "type": ["string", "null"], "description": "Short concern/note or empty if routine" },
        "flagged": { "type": ["boolean", "null"], "description": "True if this row is a security-concerning PR" }
      },
      "additionalProperties": false
    },

    "pr_sample_review": {
      "type": "object",
      "properties": {
        "$comment": { "type": "string" },
        "intro": { "type": ["string", "null"] },
        "rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/pr_sample_review_row" }
        }
      },
      "additionalProperties": false
    },

    "coverage_detail_row": {
      "type": "object",
      "required": ["check", "result"],
      "properties": {
        "check": { "type": "string" },
        "result": { "type": "string", "description": "Emoji-leading or plain text result" }
      },
      "additionalProperties": false
    },

    "coverage_detail_monorepo": {
      "$comment": "C4 FIX NOW (V2.3 R3 C11): Explicit monorepo coverage fields as typed sibling object — DeepSeek R2 dissent preferred extending generic rows[].",
      "type": "object",
      "properties": {
        "is_monorepo": { "type": ["boolean", "null"] },
        "inner_package_count": { "type": ["integer", "null"] },
        "sampled_inner_packages": {
          "type": "array",
          "items": { "type": "string" }
        },
        "lifecycle_script_hits": { "type": ["integer", "null"] }
      },
      "additionalProperties": false
    },

    "coverage_detail_pr_target_usage": {
      "$comment": "C4 FIX NOW (V2.3 R3 C11): Explicit pull_request_target usage reporting — must be stated even when 0.",
      "type": "object",
      "required": ["usage_count"],
      "properties": {
        "usage_count": { "type": "integer", "minimum": 0 },
        "workflows_checked": { "type": ["integer", "null"] },
        "note": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },

    "coverage_detail": {
      "type": "object",
      "properties": {
        "$comment": { "type": "string" },
        "rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/coverage_detail_row" }
        },
        "monorepo": { "$ref": "#/$defs/coverage_detail_monorepo" },
        "pr_target_usage": { "$ref": "#/$defs/coverage_detail_pr_target_usage" }
      },
      "additionalProperties": false
    },

    "repo_vitals_row": {
      "type": "object",
      "required": ["metric", "value"],
      "properties": {
        "metric": { "type": "string" },
        "value": { "type": "string" },
        "note": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },

    "section_lead": {
      "type": "object",
      "properties": {
        "pill_row": { "type": ["string", "null"] },
        "summary": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },

    "per_finding_prose_entry": {
      "type": "object",
      "required": ["finding_id"],
      "properties": {
        "finding_id": { "type": "string" },
        "body_paragraphs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Multi-paragraph prose body. Prose-LLM output; structural constraint only."
        },
        "what_we_observed": { "type": ["string", "null"] },
        "what_this_means": { "type": ["string", "null"] },
        "what_this_does_not_mean": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },

    "finding": {
      "type": "object",
      "required": ["id", "severity", "provenance", "status", "category", "title", "action_hint"],
      "properties": {
        "id": { "type": "string" },
        "severity": { "$ref": "#/$defs/severity" },
        "provenance": { "$ref": "#/$defs/finding_provenance" },
        "status": { "$ref": "#/$defs/finding_status" },
        "category": { "type": "string" },
        "title": { "type": "string" },
        "action_hint": { "type": "string" },
        "kind": {
          "type": ["string", "null"],
          "description": "Optional finding kind label (e.g. 'Structural', 'Hygiene', 'Supply chain'). Rendered between severity and title."
        },
        "rule_id": {
          "type": ["string", "null"],
          "description": "Reference to the scanner rule that fired (e.g. 'C20', 'F11')."
        },
        "duration_label": {
          "type": ["string", "null"],
          "description": "Per-finding metadata badge (e.g. 'Continuous', 'Current', '2024 window')."
        },
        "date_label": {
          "type": ["string", "null"],
          "description": "Date context for the finding (e.g. 'Since repo creation', '2024-01 to present')."
        },
        "how_to_fix": {
          "type": ["string", "null"],
          "description": "Concrete maintainer-side or consumer-side fix instructions. Appears below meta_table in §02."
        },
        "auto_load_tier": {
          "$ref": "#/$defs/auto_load_tier",
          "description": "C3 FIX NOW: required on findings whose category matches agent-rule-file patterns. See allOf."
        },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "threat_model_paths": {
          "type": "array",
          "items": { "$ref": "#/$defs/threat_model_path" }
        },
        "threat_model_context": { "type": ["string", "null"] },
        "what_this_means": { "type": ["string", "null"] },
        "what_this_does_not_mean": { "type": ["string", "null"] },
        "meta_table": {
          "type": "array",
          "items": { "$ref": "#/$defs/meta_table_row" }
        },
        "remediation": { "type": ["string", "null"] },
        "boundary_case": {
          "type": ["boolean", "null"],
          "description": "Flag indicating this finding sits near a severity threshold (see phase_3_computed.boundary_cases for the detailed case)."
        },
        "boundary_note": {
          "type": ["string", "null"],
          "description": "One-line human-readable note about the boundary (e.g. '31 days since latest release — 1 day outside the 30-day Critical window')."
        }
      },
      "allOf": [
        {
          "$comment": "Evidence_refs required for any non-OK finding.",
          "if": {
            "not": {
              "properties": { "severity": { "const": "OK" } }
            }
          },
          "then": {
            "required": ["evidence_refs"]
          }
        },
        {
          "$comment": "C3 FIX NOW (V2.3 R3 C9, 2026-04-18 board R3 Option X): auto_load_tier required on findings whose category matches agent-rule-file patterns. V1.2 will re-bind this to domain=='agent' per SD2 deferred roadmap (project_pipeline_architecture.md).",
          "if": {
            "properties": {
              "category": {
                "type": "string",
                "pattern": "^(supply-chain/agent-rules|code/agent-rule-file|code/agent-rule-injection)"
              }
            },
            "required": ["category"]
          },
          "then": {
            "required": ["auto_load_tier"]
          }
        }
      ],
      "additionalProperties": false
    },

    "scorecard_cell": {
      "type": "object",
      "properties": {
        "color": {
          "oneOf": [
            { "$ref": "#/$defs/scorecard_color" },
            { "type": "null" }
          ]
        },
        "short_answer": { "type": ["string", "null"] },
        "inputs": { "type": "object" }
      },
      "additionalProperties": false
    },

    "coverage_cell": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "status": { "$ref": "#/$defs/coverage_status" },
        "detail": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },

    "phase_1_raw_capture": {
      "type": "object",
      "required": ["pre_flight", "repo_metadata"],
      "properties": {
        "$comment": { "type": "string" },

        "pre_flight": {
          "type": "object",
          "required": ["head_sha", "default_branch"],
          "properties": {
            "head_sha": { "type": ["string", "null"] },
            "default_branch": { "type": ["string", "null"] },
            "tarball_extracted": { "type": "boolean" },
            "tarball_file_count": { "type": ["integer", "null"] },
            "symlinks_stripped": { "type": "boolean" },
            "api_rate_limit": {
              "type": "object",
              "properties": {
                "remaining": { "type": ["integer", "null"] },
                "limit": { "type": ["integer", "null"] },
                "reset_at": { "type": ["string", "null"] }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },

        "repo_metadata": {
          "type": "object",
          "required": ["name"],
          "properties": {
            "$comment": { "type": "string" },
            "name": { "type": ["string", "null"] },
            "description": { "type": ["string", "null"] },
            "created_at": { "type": ["string", "null"] },
            "pushed_at": { "type": ["string", "null"] },
            "stargazer_count": { "type": ["integer", "null"] },
            "fork_count": { "type": ["integer", "null"] },
            "license_spdx": { "type": ["string", "null"] },
            "default_branch_ref": { "type": ["string", "null"] },
            "is_archived": { "type": ["boolean", "null"] },
            "has_issues_enabled": { "type": ["boolean", "null"] },
            "is_fork": { "type": ["boolean", "null"] },
            "primary_language": { "type": ["string", "null"] },
            "topics": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        },

        "contributors": {
          "type": "object",
          "properties": {
            "$comment": { "type": "string" },
            "top_contributors": { "type": "array" },
            "total_contributor_count": { "type": ["integer", "null"] }
          },
          "additionalProperties": false
        },

        "maintainer_accounts": {
          "type": "object",
          "properties": {
            "$comment": { "type": "string" },
            "accounts": { "type": "array" }
          },
          "additionalProperties": false
        },

        "releases": {
          "type": "object",
          "properties": {
            "$comment": { "type": "string" },
            "entries": { "type": "array" },
            "total_count": { "type": ["integer", "null"] }
          },
          "additionalProperties": false
        },

        "community_profile": {
          "type": "object",
          "properties": {
            "$comment": { "type": "string" },
            "health_percentage": { "type": ["integer", "null"] },
            "has_code_of_conduct": { "type": ["boolean", "null"] },
            "has_contributing": { "type": ["boolean", "null"] },
            "has_security_policy": { "type": ["boolean", "null"] },
            "license_spdx": { "type": ["string", "null"] }
          },
          "additionalProperties": false
        },

        "security_advisories": {
          "type": "object",
          "properties": {
            "$comment": { "type": "string" },
            "count": { "type": ["integer", "null"] },
            "entries": { "type": "array" }
          },
          "additionalProperties": false
        },

        "workflows": {
          "type": "object",
          "properties": {
            "$comment": { "type": "string" },
            "entries": { "type": "array" },
            "count": { "type": ["integer", "null"] },
            "pull_request_target_count": { "type": ["integer", "null"] }
          },
          "additionalProperties": false
        },

        "workflow_contents": {
          "type": "object",
          "properties": {
            "$comment": { "type": "string" },
            "entries": { "type": "array" }
          },
          "additionalProperties": false
        },

        "branch_protection": {
          "type": "object",
          "properties": {
            "$comment": { "type": "string" },
            "classic": {
              "type": "object",
              "properties": {
                "status": {
                  "type": ["integer", "string", "null"],
