{# V1.2 D2: scorecard authority moved to phase_4_structured_llm #}
{% set cells = form.get('phase_4_structured_llm', {}).get('scorecard_cells', {}) or {} %}
{% set questions = [
  ('does_anyone_check_the_code', 'Does anyone check the code?'),
  ('is_it_safe_out_of_the_box', 'Is it safe out of the box?'),
  ('do_they_fix_problems_quickly', 'Do they fix problems quickly?'),
  ('do_they_tell_you_about_problems', 'Do they tell you about problems?'),
] %}
## Trust Scorecard

| Question | Answer |
|----------|--------|
{% for key, question in questions %}
{%- set cell = cells.get(key, {}) or {} -%}
{%- set color = cell.get('color') or 'amber' -%}
{%- set icon = CELL_ICON.get(color, '⚠') -%}
{%- set answer = cell.get('short_answer', '') -%}
{%- if ' — ' in answer -%}
{%- set head, _, tail = answer.partition(' — ') -%}
{%- set cell_text = '**' ~ head ~ '** — ' ~ tail -%}
{%- elif answer -%}
{%- set cell_text = '**' ~ CELL_WORD.get(color, 'Partly') ~ '** — ' ~ answer -%}
{%- else -%}
{%- set cell_text = '**' ~ CELL_WORD.get(color, 'Partly') ~ '**' -%}
{%- endif -%}
| {{ question }} | {{ icon }} {{ cell_text }} |
{% endfor %}

