        q1_color = "red"
        q1_answer = "No"
    elif any_rev >= 60 and formal >= 30 and has_any_branch_protection:
        q1_color = "green"
        q1_answer = "Yes"
    elif any_rev < 30 or (is_solo_maintainer and any_rev < 40):
