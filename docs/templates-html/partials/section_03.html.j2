{#
  Section 03 — PR sample review table. (Template labels this "Suspicious Code Changes")
  MD analogue: docs/templates/partials/section_03.md.j2
  Source scaffold: EXAMPLE-START: section-03-suspicious-prs (lines ~1508-1553)

  Data paths:
    form.phase_4_structured_llm.pr_sample_review.{intro,rows[]}
      rows[]: {number,what,author,merger,reviewed,concern,flagged,url}
    form.phase_1_raw_capture.pr_review.{prs[],formal_review_rate,sample_size,total_closed_prs}
    form.target.{owner,repo}

  td classes for reviewed column: td-reviewed-no | td-reviewed-yes | td-reviewed-rejected
  td-merge-fast for sub-24h merges (not tracked in fixture — omit)
#}
{% set pr = form.phase_1_raw_capture.get('pr_review', {}) or {} %}
{% set review_summary = form.phase_4_structured_llm.get('pr_sample_review', {}) or {} %}
{% set llm_rows = review_summary.get('rows', []) %}
{% set derived_rows = [] if llm_rows else derive_pr_sample(form.get('phase_1_raw_capture', {})) %}
{% set rows = llm_rows or derived_rows %}
{% set target = form.target %}
{% if rows %}
{% set flagged_count = llm_rows | selectattr('flagged', 'equalto', true) | list | length %}
{% set sample_total = rows | length %}
  <details class="collapsible-section">
    <summary>
      <div class="section-header">
        <span class="section-number">03</span>
        <h2>Suspicious Code Changes</h2>
        <span class="section-status">
          {% if flagged_count %}
          <span class="pill amber">&#x26A0; {{ flagged_count }} PRs flagged</span>
          {% else %}
          <span class="pill green">&#x2713; 0 flagged</span>
          {% endif %}
          <span class="pill muted">{{ sample_total }} sampled</span>
        </span>
      </div>
      {% if review_summary.get('intro') %}
      <div class="section-subtitle">{{ review_summary.intro }}</div>
      {% else %}
      <div class="section-subtitle">
        {{ sample_total }} recent merged PRs sampled.{% if pr.get('formal_review_rate') is not none %} Formal review rate: {{ pr.formal_review_rate }}%.{% endif %}
      </div>
      {% endif %}
    </summary>
    <div class="section-body">
    <div class="pr-table-wrap">
      <table>
        <thead>
          <tr>
            <th>PR</th><th>What it did</th><th>Submitted by</th>
            <th>Merged by</th><th>Reviewed?</th><th>Concern</th>
          </tr>
        </thead>
        <tbody>
          {% if llm_rows %}
          {% for r in llm_rows %}
          {% set pr_url = r.get('url') or 'https://github.com/' ~ target.owner ~ '/' ~ target.repo ~ '/pull/' ~ (r.get('number', '') | string) %}
          {% set reviewed_str = r.get('reviewed', '') | lower %}
          {% set reviewed_cls = 'td-reviewed-yes' if 'formal' in reviewed_str or 'approved' in reviewed_str else ('td-reviewed-rejected' if 'reject' in reviewed_str else 'td-reviewed-no') %}
          <tr>
            <td><a href="{{ pr_url }}">#{{ r.get('number', '') }}</a></td>
            <td>{{ r.get('what', '') }}</td>
            <td class="td-person">{{ r.get('author', '') }}</td>
            <td class="td-person">{{ r.get('merger', '') }}</td>
            <td class="{{ reviewed_cls }}">{{ r.get('reviewed', '') }}</td>
            <td class="td-concern">{{ r.get('concern', '') }}</td>
          </tr>
          {% endfor %}
          {% else %}
          {% for r in derived_rows %}
          {% set pr_url = 'https://github.com/' ~ target.owner ~ '/' ~ target.repo ~ '/pull/' ~ (r.get('number', '') | string) %}
          {% set reviewed_cls = 'td-reviewed-yes' if r.get('formal_review') or r.get('any_review') else 'td-reviewed-no' %}
          <tr>
            <td><a href="{{ pr_url }}">#{{ r.get('number', '') }}</a></td>
            <td>{{ r.get('title') or '—' }}</td>
            <td class="td-person">{{ r.get('author') or '?' }}</td>
            <td class="td-person">{{ r.get('merger') or '?' }}</td>
            <td class="{{ reviewed_cls }}">{{ r.get('formal_review') or ('yes' if r.get('any_review') else 'no') }}</td>
            <td class="td-concern">{% if r.get('self_merge') %}<strong>Self-merge</strong>{% elif r.get('security_flagged') %}<strong>Security-flagged</strong>{% else %}&mdash;{% endif %}</td>
          </tr>
          {% endfor %}
          {% endif %}
        </tbody>
      </table>
    </div>
    </div>
  </details>
{% endif %}
