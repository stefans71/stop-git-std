{#
  Footer partial — report footer with timestamp, scanner version, disclaimer.
  MD analogue: docs/templates/partials/footer.md.j2
  Source scaffold: EXAMPLE-START: footer (lines ~1977-1982)

  Data paths:
    form.target.{owner,repo}
    form.phase_1_raw_capture.pre_flight.head_sha
    form.phase_1_raw_capture.releases.entries[0].tag
    form._meta.scanner_version
#}
{% set target = form.target %}
{% set head_sha = form.phase_1_raw_capture.pre_flight.head_sha or '' %}
{% set releases = form.phase_1_raw_capture.get('releases', {}).get('entries', []) %}
{% set latest_tag = releases[0].tag if releases else 'untagged' %}
{% set scanner_ver = form.get('_meta', {}).get('scanner_version', 'unknown') %}
  <div class="footer">
    Generated by <a href="https://github.com/stefans71/stop-git-std">stop-git-std</a> deep dive &middot; {{ scan_date }} &middot; scanned main @ {{ short_sha(head_sha) }} ({{ latest_tag }}) &middot; scanner {{ scanner_ver }}
    <br>This report is an automated investigation, not a professional security audit. It may miss issues. If you are making a business decision, consult a security professional.
  </div>
